DATABASE_URL=postgresql://user:pass@host:5432/dbname
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@splanno.app
PORT=5001
APP_URL=http://localhost:5001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 uploads (optional in dev; falls back to local public/uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=splanno-uploads
R2_PUBLIC_URL=

# Stripe (public listing checkout)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PUBLIC_LISTING=price_xxx
# Optional listing duration (days). Default is 30.
# PUBLIC_LISTING_DAYS=30

# Virality / sharing: set to "false" to hide share buttons (private beta). Default: enabled.
# VITE_ENABLE_SHARING=false

# Global location autocomplete (Mapbox Geocoding API)
VITE_MAPBOX_TOKEN=pk_xxx

# Email verification banner: set to "false" to hide until email delivery is ready.
VITE_SHOW_VERIFY_BANNER=false
