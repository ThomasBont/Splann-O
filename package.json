{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx -r dotenv/config server/index.ts",
    "dev:clean": "kill -9 $(lsof -t -i:5001) 2>/dev/null || true && NODE_ENV=development tsx -r dotenv/config server/index.ts",
    "build": "tsx script/build.ts",
    "smoke": "node script/smoke.mjs",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "db:check": "npx tsx script/db-migrate.ts check",
    "db:migrate": "npx tsx script/db-migrate.ts migrate",
    "db:reset": "npx tsx script/db-reset.ts --yes",
    "db:seed": "npx tsx script/db-seed.ts",
    "db:seed:private": "npx tsx script/db-seed.ts --only-seed-private",
    "db:seed:public": "npx tsx script/db-seed.ts --only-seed-public",
    "db:reset:seed": "npm run db:reset && npm run db:seed",
    "db:reset:dev": "NODE_ENV=development npx tsx script/db-reset-dev.ts",
    "db:seed:dev": "NODE_ENV=development npx tsx script/db-seed-dev.ts",
    "db:refresh:dev": "npm run db:migrate && npm run db:reset:dev && npm run db:seed:dev",
    "db:repair-private-events": "npx tsx script/repair-private-events.ts",
    "db:migrate:plan": "psql \"$DATABASE_URL\" -f migrations/0005_phase3_plan_tiers.sql",
    "split:verify": "npx tsx client/src/lib/split/calc.verify.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
